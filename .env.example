# PermitWatch AI — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ── Backend API ──
# Set this to your backend URL to switch from mock data to real API calls.
# Leave blank to use built-in mock data (default for development).
# Example: VITE_API_BASE_URL=https://api.permitwatch.ai
VITE_API_BASE_URL=

# ── Apify Scraping ──
# Your Apify API token from https://console.apify.com/account/integrations
# Leave blank to use mock scraped data for development.
VITE_APIFY_TOKEN=

# Optional: Override actor IDs (defaults use placeholder actor names)
# VITE_APIFY_ACTOR_SF_DBI=permitwatch/sf-dbi-scraper
# VITE_APIFY_ACTOR_SF_PLAN=permitwatch/sf-planning-scraper
# VITE_APIFY_ACTOR_SJ_PERMIT=permitwatch/sj-permit-scraper

# ── AI Verification Agent ──
# OpenAI-compatible endpoint for opportunity analysis.
# Leave blank to use mock analysis with low-confidence defaults.
# Example: VITE_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# For Google Gemini: VITE_AI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
VITE_AI_ENDPOINT=
VITE_AI_API_KEY=
VITE_AI_MODEL=gemini-2.0-flash

# ── Supabase (Lovable-ready) ──
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── Stripe Monetization ──
# VITE_STRIPE_PUBLISHABLE_KEY=
